# ───────── Core ─────────
NODE_ENV=development
LOG_LEVEL=info

# ───────── Controller ─────────
CONTROLLER_HOST=0.0.0.0
CONTROLLER_PORT=8080
# Secret used to sign the dashboard session cookie (cp_session).
# When DASHBOARD_PASSWORD_HASH is set, this MUST be a real >=32 char secret
# (the boot guard rejects 'change-me' / 'change-me-in-prod' / shorter values).
# Rotate to invalidate every active dashboard session.
CONTROLLER_JWT_SECRET=change-me-in-prod
# Comma-separated bearer tokens for service clients (CI, scripts).
# The Telegram bot runs in-process and does not use one.
CONTROLLER_API_TOKENS=ci:replace-me
# Everything app-owned (build workdirs, rsync staging, artifact store) lives
# under a single project-local tmp/ tree so it's easy to inspect and wipe.
# Defaults are: <repo>/tmp/builds, <repo>/tmp/staging, <repo>/tmp/artifacts.
# Set absolute paths for production.
# CP_TMP_DIR=/var/lib/controlplane
# BUILD_WORKDIR_BASE=/var/lib/controlplane/builds
# RSYNC_STAGING_DIR=/var/lib/controlplane/staging
# ARTIFACT_STORE_DIR=/var/lib/controlplane/artifacts
BUILD_TIMEOUT_MS=1800000

# Controller ↔ target servers: the controller drives every server over SSH.
# Per-server auth lives in the controller user's ~/.ssh/config. A typical
# block (enabling connection reuse across the 30s state polls and on-demand
# jobs) looks like:
#
#   Host app-eu-1
#     HostName 10.0.3.17
#     User deploy
#     IdentityFile ~/.ssh/id_ed25519
#     ControlMaster auto
#     ControlPath   ~/.ssh/cm-%r@%h:%p
#     ControlPersist 10m
#
# Then register the server in the dashboard with hostname=app-eu-1.

# How often the controller SSH-polls each server for liveness + per-app
# process state. Default 30s is a good balance between freshness and load.
# STATE_POLL_INTERVAL_MS=30000

# ───────── Dashboard auth ─────────
# bcrypt hash of the dashboard password.
# Generate with:  echo -n 'your-password' | npm run dashboard:hash --silent
DASHBOARD_PASSWORD_HASH=

# ───────── MySQL ─────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=controlplane
DB_POOL_SIZE=10

# ───────── Queue ─────────
WORKER_CONCURRENCY=4
# Per-action retry count. Controls how many total attempts a failed job gets
# (attempts=1 → no retry). Backoff timing stays fixed in code.
RETRY_START_ATTEMPTS=3
RETRY_STOP_ATTEMPTS=2
RETRY_RESTART_ATTEMPTS=3
RETRY_BUILD_ATTEMPTS=2
RETRY_DEPLOY_ATTEMPTS=2
RETRY_HEALTHCHECK_ATTEMPTS=1

# ───────── Telegram Bot (optional — leave TELEGRAM_TOKEN blank to disable) ─────────
TELEGRAM_TOKEN=
# Comma-separated chat IDs allowed to issue destructive commands
TELEGRAM_ADMIN_CHAT_IDS=
