# ───────── Core ─────────
NODE_ENV=development
LOG_LEVEL=info

# ───────── Controller ─────────
CONTROLLER_HOST=0.0.0.0
CONTROLLER_PORT=8080
# Secret used to sign session cookies / JWTs for human users
CONTROLLER_JWT_SECRET=change-me-in-prod
# Comma-separated API tokens granted to service clients (bot, CI, etc.)
CONTROLLER_API_TOKENS=telegram-bot:replace-me,ci:replace-me

# ───────── Agent ─────────
AGENT_ID=agent-local
AGENT_SERVER_NAME=local-dev
# URL the agent uses to reach the controller
CONTROLLER_WS_URL=ws://127.0.0.1:8080/agent
# Bearer token the agent presents (matches servers.auth_token in DB)
AGENT_AUTH_TOKEN=replace-me
AGENT_HEARTBEAT_MS=10000
# Root directory under which applications are deployed
AGENT_WORKDIR=/var/lib/controlplane/apps

# ───────── MySQL ─────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=controlplane
DB_POOL_SIZE=10

# ───────── Redis / BullMQ ─────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
QUEUE_PREFIX=cp

# ───────── Telegram Bot ─────────
TELEGRAM_TOKEN=
# Controller endpoint the bot talks to
TELEGRAM_CONTROLLER_URL=http://127.0.0.1:8080
# API token the bot uses when calling the controller
TELEGRAM_CONTROLLER_TOKEN=replace-me
# Comma-separated chat IDs allowed to issue destructive commands
TELEGRAM_ADMIN_CHAT_IDS=

# ───────── Web ─────────
WEB_PORT=8081
